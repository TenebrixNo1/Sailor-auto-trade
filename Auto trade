--------------------------------------------------
-- 📤 SEND SET (เหมือนเดิม)
--------------------------------------------------
local function sendSet(setName)
    if not inventory or next(inventory) == nil then return end
	
	repeat task.wait() until inventory and next(inventory) ~= nil
    task.wait(1)

    local items = Sets[setName]
    if not items then return end

    local missing = {}

    for _, item in ipairs(items) do
        local need = item.amount * setMultiplier
        if getAmount(item.name) < need then
            table.insert(missing, item.name)
        end
    end

    if selectedExtraItem and extraAmount > 0 then
        if getAmount(selectedExtraItem) < extraAmount then
            table.insert(missing, selectedExtraItem)
        end
    end

    if #missing > 0 then
        Rayfield:Notify({
            Title = "Missing",
            Content = table.concat(missing, ", "),
            Duration = 5
        })
        return
    end

    for _, item in ipairs(items) do
        tradeRemote:FireServer("Items", item.name, item.amount * setMultiplier)
        task.wait(0.7)
    end

    if selectedExtraItem and extraAmount > 0 then
        tradeRemote:FireServer("Items", selectedExtraItem, extraAmount)
        task.wait(0.7)
    end

    if autoConfirmEnabled then
        autoTradeConfirm()
    end
end

