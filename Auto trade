-- 🤖 AUTO CONFIRM (เหมือนเดิม)
--------------------------------------------------
local tradeState = {
    theirReady = false,
    phase = "",
    theirConfirm = false
}

local tradeUpdate = Remotes:WaitForChild("TradeRemotes"):WaitForChild("TradeUpdated")

tradeUpdate.OnClientEvent:Connect(function(data)
    if typeof(data) ~= "table" then return end
    tradeState.theirReady = data.theirReady or tradeState.theirReady
    tradeState.phase = data.phase or tradeState.phase
    tradeState.theirConfirm = data.theirConfirm or tradeState.theirConfirm
end)

local autoConfirmEnabled = true

Tab:CreateToggle({
    Name = "Auto Ready + Confirm",
    CurrentValue = true,
    Callback = function(val)
        autoConfirmEnabled = val
    end,
})

local function autoTradeConfirm()
    if not autoConfirmEnabled then return end

    readyRemote:FireServer(true)

    repeat task.wait() until tradeState.theirReady == true
    repeat task.wait() until tradeState.phase == "confirming"

    repeat
        confirmRemote:FireServer()
        task.wait(0.5)
    until tradeState.theirConfirm == true
end

