local requestInv = Remotes:WaitForChild("RequestInventory")

--------------------------------------------------
-- 🔤 NORMALIZE
--------------------------------------------------
local function normalize(str)
    return string.lower(string.gsub(tostring(str), "%s+", ""))
end

--------------------------------------------------
-- 📦 INVENTORY + SEARCH SYSTEM
--------------------------------------------------
local inventory = {}
local allItems = {}

local selectedExtraItem = nil
local extraAmount = 0
local ExtraDropdown = nil

invRemote.OnClientEvent:Connect(function(category, data)
    if category == "Items" and typeof(data) == "table" then
        inventory = data
        allItems = {}

        local seen = {}

        for _, item in pairs(inventory) do
            local name = item.name or item.Name
            if name and not seen[name] then
                seen[name] = true
                table.insert(allItems, name)
            end
        end

        table.sort(allItems)

        if ExtraDropdown then
            ExtraDropdown:Refresh(allItems)
        end
    end
end)

requestInv:FireServer()

--------------------------------------------------
-- 🔍 GET AMOUNT
--------------------------------------------------
local function getAmount(itemName)
    local target = normalize(itemName)

    for _, item in pairs(inventory) do
        local name = item.name or item.Name
        local amount = item.quantity or item.Quantity or item.amount or 0

        if name and normalize(name) == target then
            return amount
        end
    end

    return 0
end

